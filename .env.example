# Database connection URL for Prisma
# For local development with docker-compose:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team4_dev"

# For production/Azure Database for PostgreSQL:
# DATABASE_URL="postgresql://user:password@server.postgres.database.azure.com:5432/database"

# AWS S3 Configuration for CV uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name

# API Configuration
API_PORT=8080
NODE_ENV=development

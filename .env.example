# Database connection URL for Prisma
# For local development: postgresql://postgres:postgres@localhost:5432/team4db
# For Docker: postgresql://postgres:postgres@db:5432/team4db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/team4db"

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3 Configuration for CV uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
